// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum Role {
  student
  tutor
  admin
}

enum BookingStatus {
  confirmed
  completed
  cancelled
  no_show
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum SessionStatus {
  scheduled
  ongoing
  completed
  cancelled
}

enum VisibilityStatus {
  public
  private
}

enum NotificationType {
  booking_confirmed
  payment_confirmed
  session_reminder
  booking_cancelled
}

enum NotificationChannel {
  in_app
  email
}

enum NotificationStatus {
  pending
  sent
  failed
}

// USER

model User {
  id String @id @default(uuid())

  name      String  @default("")
  email     String  @unique
  firstName String?
  lastName  String?
  role      Role    @default(student)

  avatarUrl  String?
  isBanned   Boolean @default(false)
  isVerified Boolean @default(false)

  emailVerified Boolean @default(false)
  image         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tutorProfile      TutorProfile?
  bookings          Booking[]      @relation("StudentBookings")
  cancelledBookings Booking[]      @relation("BookingCancelledBy")
  reviews           Review[]
  notifications     Notification[]

  accounts Account[]
  sessions AuthSession[]

  @@index([email])
}

// TUTOR PROFILE

model TutorProfile {
  id     String @id @default(uuid())
  userId String @unique

  professionalTitle String @default("")
  bio             String @default("")
  hourlyRate      Float  @default(0)
  experienceYears Int    @default(0)

  totalHoursTaught Float @default(0)
  totalEarnings    Float @default(0)

  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  isTopRated Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  categories   TutorCategory[]
  education    TutorEducation[]
  expertise    TutorExpertise[]
  availability AvailabilitySlot[]
  bookings     Booking[]
  reviews      Review[]

  @@index([hourlyRate])
  @@index([averageRating])
  @@index([isTopRated])
}

// CATEGORY

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  tutors TutorCategory[]
}

// TUTOR CATEGORY (M:N)

model TutorCategory {
  id String @id @default(uuid())

  tutorId    String
  categoryId String

  tutor    TutorProfile @relation(fields: [tutorId], references: [id])
  category Category     @relation(fields: [categoryId], references: [id])

  @@unique([tutorId, categoryId])
}

// TUTOR EDUCATION

model TutorEducation {
  id String @id @default(uuid())

  tutorId String

  degree       String
  institution  String
  fieldOfStudy String
  startYear    Int
  endYear      Int?
  description  String?

  tutor TutorProfile @relation(fields: [tutorId], references: [id])
}

// TUTOR EXPERTISE

model TutorExpertise {
  id String @id @default(uuid())

  tutorId String
  name    String
  slug    String

  tutor TutorProfile @relation(fields: [tutorId], references: [id])
}

// AVAILABILITY

model AvailabilitySlot {
  id String @id @default(uuid())

  tutorId String

  startAt DateTime
  endAt   DateTime

  isBooked Boolean @default(false)

  recurringGroupId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tutor   TutorProfile @relation(fields: [tutorId], references: [id])
  booking Booking?

  @@index([startAt, isBooked])
  @@index([tutorId, startAt])
}

// BOOKING

model Booking {
  id String @id @default(uuid())

  studentId String
  tutorId   String
  slotId    String @unique

  status BookingStatus

  sessionDate DateTime
  startTime   DateTime
  endTime     DateTime

  priceAtBooking Float

  paymentStatus    PaymentStatus @default(pending)
  paidAt           DateTime?
  paymentMethod    String?
  paymentReference String?

  cancelledAt        DateTime?
  cancelledByUserId  String?
  cancellationReason String?
  completedAt        DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  student     User             @relation("StudentBookings", fields: [studentId], references: [id])
  tutor       TutorProfile     @relation(fields: [tutorId], references: [id])
  slot        AvailabilitySlot @relation(fields: [slotId], references: [id])
  cancelledBy User?            @relation("BookingCancelledBy", fields: [cancelledByUserId], references: [id])

  session       Session?
  review        Review?
  notifications Notification[]

  @@index([studentId])
  @@index([tutorId])
  @@index([status])
  @@index([sessionDate])
  @@index([paymentStatus])
  @@index([studentId, status])
  @@index([tutorId, status])
}

// SESSION

model Session {
  id String @id @default(uuid())

  bookingId String @unique

  meetingProvider String?
  meetingId       String?
  meetingJoinUrl  String?
  meetingHostUrl  String?
  meetingPassword String?

  actualStartTime DateTime?
  actualEndTime   DateTime?

  durationHours Float?

  status SessionStatus

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

// REVIEW

model Review {
  id String @id @default(uuid())

  bookingId String @unique
  studentId String
  tutorId   String

  rating  Int
  comment String?

  isVisible Boolean @default(true)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  booking Booking      @relation(fields: [bookingId], references: [id])
  student User         @relation(fields: [studentId], references: [id])
  tutor   TutorProfile @relation(fields: [tutorId], references: [id])
}

model Notification {
  id           String              @id @default(uuid())
  userId       String
  bookingId    String?
  type         NotificationType
  channel      NotificationChannel
  title        String
  message      String
  status       NotificationStatus  @default(pending)
  scheduledFor DateTime?
  sentAt       DateTime?
  readAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId, readAt])
  @@index([status, scheduledFor])
  @@index([bookingId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
